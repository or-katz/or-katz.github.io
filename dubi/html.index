<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>דובי הקצב</title>
    <!-- טעינת Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @keyframes scrollBg {
            from { background-position: 0 0; }
            to { background-position: -1000px 0; }
        }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-float {
            animation: float 3s ease-in-out infinite;
        }
        .street-bg {
            background-image: repeating-linear-gradient(-90deg, transparent, transparent 60px, rgba(255,255,255,0.2) 60px, rgba(255,255,255,0.2) 100px);
            background-size: 1000px 100%;
            animation: scrollBg 2s linear infinite;
        }
        .tile-bg {
            background-color: #7f1d1d;
            background-image: linear-gradient(335deg, rgba(255,255,255,0.1) 25%, transparent 25%),
                              linear-gradient(155deg, rgba(255,255,255,0.1) 25%, transparent 25%),
                              linear-gradient(335deg, rgba(255,255,255,0.1) 25%, transparent 25%),
                              linear-gradient(155deg, rgba(255,255,255,0.1) 25%, transparent 25%);
            background-size: 30px 30px;
            background-position: 0 0, 15px 15px, 15px 15px, 0 0;
        }
        @keyframes popIn {
            0% { transform: scale(0); opacity: 0; }
            80% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        .animate-pop {
            animation: popIn 0.3s ease-out forwards;
        }
        .fly-transition {
            transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }
        
        /* מניעת סימון טקסט בטעות */
        body {
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
            touch-action: manipulation;
        }
    </style>
</head>
<body class="w-full h-[100dvh] bg-neutral-900 flex items-center justify-center font-sans overflow-hidden">

    <!-- Game Container -->
    <div id="game-container" class="relative w-full h-full max-w-md md:max-w-4xl bg-sky-200 overflow-hidden shadow-2xl md:rounded-3xl md:h-[80vh] border-0 md:border-4 border-neutral-800">
        
        <!-- Top UI Bar -->
        <div id="top-ui" class="hidden absolute top-0 left-0 w-full p-2 md:p-4 flex justify-between items-start z-50 pointer-events-none text-white drop-shadow-md">
            <div class="bg-neutral-800/90 px-3 py-2 rounded-xl border-2 border-neutral-600 font-bold text-sm md:text-xl flex flex-col items-center shadow-lg">
                <span class="text-yellow-400" id="ui-day">יום 1</span>
                <span id="ui-score">₪0</span>
            </div>
            
            <div class="bg-blue-600/90 px-3 py-2 rounded-xl border-2 border-blue-400 font-bold text-sm md:text-xl flex flex-col items-center shadow-lg">
                <span>בארגז</span>
                <span id="ui-inventory" class="text-white">0 / 10</span>
            </div>
        </div>

        <!-- Messages -->
        <div id="message-box" class="hidden absolute top-1/3 left-1/2 -translate-x-1/2 z-[100] animate-bounce w-[90%] text-center">
            <div id="message-text" class="bg-yellow-400 text-black px-4 md:px-6 py-2 md:py-3 rounded-2xl font-black text-xl md:text-2xl shadow-[0_4px_0_#b45309] border-4 border-yellow-600 inline-block">
                <!-- Text goes here -->
            </div>
        </div>

        <!-- Screen 1: START -->
        <div id="screen-start" class="absolute inset-0 bg-red-800 flex flex-col items-center justify-center p-4 text-center">
            <div class="absolute inset-0 tile-bg opacity-40"></div>
            
            <div class="relative z-10 bg-white/95 p-6 md:p-8 rounded-3xl shadow-2xl w-full max-w-[90%] md:max-w-lg border-8 border-neutral-900 animate-pop">
                <h1 class="text-5xl md:text-6xl font-black text-red-600 mb-2 drop-shadow-sm">דובי הקצב</h1>
                <h2 class="text-xl md:text-2xl font-bold text-neutral-700 mb-6">משלוחי בשר אקספרס</h2>
                
                <div class="w-40 h-40 md:w-48 md:h-48 mx-auto mb-6 bg-red-50 rounded-full border-4 border-red-200 overflow-hidden relative shadow-inner">
                    <div id="start-character-container" class="absolute bottom-[-10px] left-[-15px] w-[180px] h-[220px] md:w-[200px] md:h-[250px]">
                        <!-- Start SVG will be injected here -->
                    </div>
                </div>
                
                <p class="text-md md:text-lg text-neutral-600 mb-8 font-medium">
                    עזור לדובי להעמיס סטייקים ועופות על האופניים החשמליים, ולחלק אותם ללקוחות הרעבים!
                </p>

                <button onclick="startGame()" class="bg-green-500 hover:bg-green-400 text-white font-black text-2xl md:text-3xl py-4 px-8 md:px-12 rounded-2xl shadow-[0_6px_0_#166534] active:shadow-[0_0px_0_#166534] active:translate-y-[6px] transition-all w-full">
                    !בוא נתחיל
                </button>
            </div>
        </div>

        <!-- Screen 2: SHOP -->
        <div id="screen-shop" class="hidden absolute inset-0 flex flex-col justify-end bg-neutral-800">
            <div class="absolute inset-0 tile-bg opacity-80"></div>
            
            <!-- Sign -->
            <div class="absolute top-14 md:top-6 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center w-[90%] md:w-auto pointer-events-none">
                <div class="flex gap-16 md:gap-32 mb-[-10px] z-0">
                    <div class="w-1 md:w-2 h-10 md:h-14 border-x-2 border-neutral-400 border-dashed"></div>
                    <div class="w-1 md:w-2 h-10 md:h-14 border-x-2 border-neutral-400 border-dashed"></div>
                </div>
                <div class="bg-[#5c3a21] border-4 md:border-[6px] border-[#3e2723] px-6 md:px-12 py-3 rounded-2xl shadow-2xl transform -rotate-2 z-10 relative overflow-hidden w-full text-center">
                    <div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(45deg,transparent,transparent_10px,rgba(0,0,0,0.2)_10px,rgba(0,0,0,0.2)_20px)]"></div>
                    <h1 class="text-4xl md:text-6xl font-black text-[#facc15] drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)] tracking-wide relative z-20" style="font-family: system-ui, sans-serif;">
                        תאוות בשרים
                    </h1>
                </div>
            </div>

            <!-- Dubi -->
            <div id="shop-character-container" class="absolute bottom-[20vh] left-1/2 -translate-x-1/2 w-[70vw] max-w-[300px] h-[50vh] max-h-[400px] z-10 pointer-events-none"></div>

            <!-- Counter -->
            <div class="relative z-20 w-full h-[25vh] md:h-[300px] bg-gradient-to-b from-gray-100 to-gray-400 border-t-4 border-gray-300 shadow-[0_-10px_30px_rgba(0,0,0,0.5)] flex flex-col">
                <div class="absolute top-0 left-0 w-full h-4 md:h-8 bg-white/30 pointer-events-none"></div>
                
                <div class="flex-1 flex justify-center items-center gap-4 md:gap-12 p-2">
                    <button id="btn-steak" onclick="handleCollect('steak', event)" class="relative group bg-white/90 p-3 md:p-6 rounded-2xl shadow-xl border-4 border-red-200 transition-transform active:scale-95">
                        <div class="text-5xl md:text-7xl drop-shadow-lg pointer-events-none">🥩</div>
                        <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-red-600 text-white font-bold px-3 py-1 rounded-full text-xs md:text-lg shadow-md whitespace-nowrap pointer-events-none">
                            סטייק
                        </div>
                    </button>

                    <button id="btn-chicken" onclick="handleCollect('chicken', event)" class="relative group bg-white/90 p-3 md:p-6 rounded-2xl shadow-xl border-4 border-orange-200 transition-transform active:scale-95">
                        <div class="text-5xl md:text-7xl drop-shadow-lg pointer-events-none">🍗</div>
                        <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-orange-500 text-white font-bold px-3 py-1 rounded-full text-xs md:text-lg shadow-md whitespace-nowrap pointer-events-none">
                            עוף
                        </div>
                    </button>
                </div>
            </div>

            <!-- Parked Bike -->
            <div class="absolute bottom-[22vh] left-2 w-[50vw] max-w-[200px] h-[150px] z-30 opacity-95 pointer-events-none">
                <div id="shop-bike-container" class="w-full h-full"></div>
                <div id="bike-box-target" class="absolute top-[20%] left-[20%] w-[40%] h-[40%] opacity-0"></div>
            </div>

            <!-- Action Button (Go to Delivery) -->
            <div id="shop-full-overlay" class="hidden absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 animate-pop w-full px-4 text-center">
                <div class="bg-black/80 text-white text-xl md:text-2xl font-bold mb-4 py-2 px-6 rounded-xl inline-block backdrop-blur-sm border-2 border-white/20">הארגז מלא עד אפס מקום!</div>
                <button onclick="goToDelivery()" class="w-full max-w-sm mx-auto bg-blue-600 hover:bg-blue-500 text-white font-black text-3xl md:text-4xl py-4 md:py-6 px-8 rounded-3xl shadow-[0_8px_0_#1e3a8a] active:shadow-[0_0px_0_#1e3a8a] active:translate-y-[8px] transition-all flex items-center justify-center gap-4 border-4 border-blue-300 pointer-events-auto">
                    <span>צא לחלוקה!</span>
                    <span class="text-4xl md:text-5xl">🚲</span>
                </button>
            </div>
        </div>

        <!-- Screen 3: DELIVERY -->
        <div id="screen-delivery" class="hidden absolute inset-0 bg-sky-300 overflow-hidden cursor-crosshair">
            <div class="absolute inset-0 bg-neutral-600 top-[60%] street-bg pointer-events-none"></div>
            
            <!-- Scenery -->
            <div class="absolute top-10 left-10 text-5xl md:text-6xl text-white/80 animate-float pointer-events-none" style="animation-delay: 0s;">☁️</div>
            <div class="absolute top-24 right-10 text-6xl md:text-7xl text-white/80 animate-float pointer-events-none" style="animation-delay: 1s;">☁️</div>
            <div class="absolute top-[50%] left-0 w-full h-8 bg-green-500 border-t-4 border-green-600 pointer-events-none"></div>

            <!-- Dubi on Bike -->
            <div class="absolute bottom-[10vh] left-[-20px] md:left-10 w-[60vw] max-w-[250px] aspect-square z-30 animate-float pointer-events-none" style="animation-duration: 0.6s;">
                <div id="delivery-bike-container" class="absolute inset-0 z-10"></div>
                <div id="delivery-character-container" class="absolute bottom-[25%] left-[15%] w-[60%] h-[60%] z-20"></div>
            </div>

            <!-- Customers Container -->
            <div id="customers-layer" class="absolute inset-0 z-20"></div>

            <!-- Instructions -->
            <div class="absolute bottom-4 w-full text-center z-50 pointer-events-none px-4">
                <span class="bg-black/80 text-white px-4 py-2 rounded-full font-bold text-sm md:text-lg backdrop-blur-sm shadow-lg block border border-white/20">
                    גע בלקוחות כדי לזרוק להם בשר! 🎯
                </span>
            </div>
        </div>

        <!-- Flying Items Container -->
        <div id="flying-layer" class="fixed inset-0 pointer-events-none z-[100] overflow-hidden"></div>

    </div>

<script>
// --- הגדרות משתמש (הכנס תמונות Base64 כאן) ---
const DUBI_FRONT_BASE64_IMAGE = ""; // תמונה מלפנים לחנות
const DUBI_SIDE_BASE64_IMAGE = "";  // תמונה מהצד לאופניים
// ----------------------------------------------

// --- ניהול מצב (State) ---
let gameState = 'START';
let inventory = [];
let score = 0;
let day = 1;
const maxCapacity = 10;
let messageTimeout = null;
let customers = [];
let gameLoopInterval = null;

// --- תבניות SVG (כפונקציות שמחזירות מחרוזות) ---

function getHighQualityDubiFaceSVG() {
    return `
    <g>
        <defs>
            <radialGradient id="skinBase" cx="50%" cy="50%" r="50%" fx="30%" fy="30%">
                <stop offset="0%" stop-color="#fcd3b3" />
                <stop offset="70%" stop-color="#f4c29f" />
                <stop offset="100%" stop-color="#d99f7a" />
            </radialGradient>
            <linearGradient id="beardGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#333333" stop-opacity="0.8" />
                <stop offset="50%" stop-color="#1a1a1a" stop-opacity="0.95" />
                <stop offset="100%" stop-color="#000000" stop-opacity="1" />
            </linearGradient>
            <radialGradient id="baldHighlight" cx="50%" cy="20%" r="40%">
                <stop offset="0%" stop-color="#ffffff" stop-opacity="0.4" />
                <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
            </radialGradient>
        </defs>
        <ellipse cx="100" cy="65" rx="38" ry="48" fill="url(#skinBase)" />
        <ellipse cx="95" cy="35" rx="25" ry="15" fill="url(#baldHighlight)" transform="rotate(-15 95 35)" />
        <path d="M 80 32 Q 100 28 120 32" stroke="#d99f7a" stroke-width="1.5" fill="none" opacity="0.6" stroke-linecap="round" />
        <path d="M 85 26 Q 100 23 115 26" stroke="#d99f7a" stroke-width="1" fill="none" opacity="0.5" stroke-linecap="round" />
        <path d="M 62 65 Q 65 135 100 120 Q 135 135 138 65 Q 140 85 100 110 Q 60 85 62 65 Z" fill="url(#beardGrad)" />
        <path d="M 64 65 Q 100 110 136 65 Q 130 55 100 80 Q 70 55 64 65 Z" fill="#222" opacity="0.3" />
        <path d="M 72 75 Q 100 62 128 75 Q 120 88 100 82 Q 80 88 72 75 Z" fill="#111" />
        <ellipse cx="85" cy="52" rx="10" ry="6" fill="#d99f7a" opacity="0.6" />
        <ellipse cx="115" cy="52" rx="10" ry="6" fill="#d99f7a" opacity="0.6" />
        <ellipse cx="85" cy="52" rx="6" ry="3" fill="#fff" />
        <ellipse cx="115" cy="52" rx="6" ry="3" fill="#fff" />
        <circle cx="85" cy="52" r="2.5" fill="#111" />
        <circle cx="115" cy="52" r="2.5" fill="#111" />
        <path d="M 70 45 L 92 50 Q 95 50 90 48 L 72 43 Z" fill="#111" />
        <path d="M 130 45 L 108 50 Q 105 50 110 48 L 128 43 Z" fill="#111" />
        <path d="M 100 55 L 93 72 Q 100 76 107 72 Z" fill="#d99f7a" />
        <path d="M 95 70 Q 100 73 105 70" stroke="#b67a5a" stroke-width="1.5" fill="none" stroke-linecap="round" />
        <path d="M 92 88 Q 100 92 108 88" stroke="#a55a4a" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.8" />
    </g>`;
}

function getShopCharacterHTML() {
    let html = `<div class="relative w-full h-full drop-shadow-2xl">
        <svg viewBox="0 0 200 300" class="w-full h-full absolute inset-0 z-10">
            <!-- Body -->
            <path d="M 30 130 Q 100 110 170 130 L 180 220 Q 100 250 20 220 Z" fill="#111111" />
            <path d="M 30 130 L 10 190 L 35 200 L 50 140" fill="#111111" />
            <path d="M 170 130 L 195 180 L 175 195 L 145 150" fill="#111111" />
            <!-- Jeans -->
            <rect x="50" y="220" width="45" height="80" fill="#3b82f6" rx="5" />
            <rect x="105" y="220" width="45" height="80" fill="#3b82f6" rx="5" />
            <path d="M 115 260 Q 125 250 140 255 L 135 270 Q 125 275 115 265 Z" fill="#f4c29f" />
            <path d="M 112 260 L 142 255 M 115 265 L 138 268" stroke="white" stroke-width="2" stroke-linecap="round" />`;

    if (!DUBI_FRONT_BASE64_IMAGE) {
        html += getHighQualityDubiFaceSVG();
    }

    html += `<!-- Hand & Knife -->
            <circle cx="185" cy="190" r="14" fill="#f4c29f" />
            <path d="M 185 180 L 290 160 L 290 195 L 175 195 Z" fill="#e5e7eb" stroke="#9ca3af" stroke-width="2" stroke-linejoin="round" />
            <path d="M 185 185 L 270 170" stroke="#fff" stroke-width="2" opacity="0.6" />
            <rect x="150" y="178" width="45" height="18" fill="#eab308" rx="4" transform="rotate(5 170 185)" />
            <circle cx="160" cy="188" r="3" fill="#333" opacity="0.6"/>
            <circle cx="175" cy="189" r="3" fill="#333" opacity="0.6"/>
            <circle cx="25" cy="195" r="12" fill="#f4c29f" />
        </svg>`;

    if (DUBI_FRONT_BASE64_IMAGE) {
        html += `<div class="absolute top-[5%] left-[31%] w-[38%] h-[32%] z-20 rounded-[40%] overflow-hidden border-4 border-[#111] bg-[#f4c29f]">
            <img src="${DUBI_FRONT_BASE64_IMAGE}" alt="Dubi" class="w-full h-full object-cover" style="object-position: center 15%;" />
        </div>`;
    }
    
    html += `</div>`;
    return html;
}

function getRidingCharacterHTML() {
    let html = `<div class="relative w-full h-full drop-shadow-lg">
        <svg viewBox="0 0 150 200" class="w-full h-full absolute inset-0 z-10">
            <!-- Body -->
            <path d="M 50 120 Q 110 90 140 120 L 120 170 Q 70 180 40 160 Z" fill="#111111" />
            <!-- Arm -->
            <path d="M 130 110 L 160 140" stroke="#111111" stroke-width="20" stroke-linecap="round" />
            <circle cx="160" cy="140" r="10" fill="#f4c29f" />
            <!-- Leg -->
            <path d="M 60 160 L 80 200 L 100 200" stroke="#3b82f6" stroke-width="25" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            <path d="M 100 200 L 115 200" stroke="#222" stroke-width="15" stroke-linecap="round" />`;

    if (!DUBI_SIDE_BASE64_IMAGE) {
        html += `<g transform="translate(110, 55) rotate(15) scale(-1, 1) translate(-100, -65)">
                    ${getHighQualityDubiFaceSVG()}
                 </g>`;
    }
    html += `</svg>`;

    if (DUBI_SIDE_BASE64_IMAGE) {
        html += `<div class="absolute top-[7.5%] left-[51%] w-[42%] h-[42%] z-20 rounded-[40%] overflow-hidden border-4 border-[#111] bg-[#f4c29f]" style="transform: rotate(15deg)">
            <img src="${DUBI_SIDE_BASE64_IMAGE}" alt="Dubi Side" class="w-full h-full object-cover" style="object-position: center 15%;" />
        </div>`;
    }

    html += `</div>`;
    return html;
}

function getElectricBikeHTML(isRiding) {
    let spinClass = isRiding ? "animate-spin" : "";
    
    let html = `<svg viewBox="0 0 320 200" class="w-full h-full">
        <!-- Wheels -->
        <g class="${spinClass}" style="transform-origin: 60px 160px;">
            <circle cx="60" cy="160" r="35" fill="none" stroke="#262626" stroke-width="12" />
            <circle cx="60" cy="160" r="25" fill="none" stroke="#d4d4d8" stroke-width="4" />
            <line x1="60" y1="125" x2="60" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(0 60 160)" />
            <line x1="60" y1="125" x2="60" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(45 60 160)" />
            <line x1="60" y1="125" x2="60" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(90 60 160)" />
            <line x1="60" y1="125" x2="60" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(135 60 160)" />
        </g>
        <g class="${spinClass}" style="transform-origin: 240px 160px;">
            <circle cx="240" cy="160" r="35" fill="none" stroke="#262626" stroke-width="12" />
            <circle cx="240" cy="160" r="25" fill="none" stroke="#d4d4d8" stroke-width="4" />
            <line x1="240" y1="125" x2="240" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(0 240 160)" />
            <line x1="240" y1="125" x2="240" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(45 240 160)" />
            <line x1="240" y1="125" x2="240" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(90 240 160)" />
            <line x1="240" y1="125" x2="240" y2="195" stroke="#a1a1aa" stroke-width="1" transform="rotate(135 240 160)" />
        </g>
        <!-- Frame -->
        <path d="M 60 160 L 120 90 L 220 90 L 240 160" fill="none" stroke="#18181b" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M 120 90 L 90 160" fill="none" stroke="#18181b" stroke-width="8" stroke-linecap="round" />
        <rect x="130" y="95" width="60" height="20" fill="#3f3f46" rx="5" transform="rotate(15 130 95)" />
        <!-- Seat & Handlebars -->
        <line x1="105" y1="125" x2="90" y2="65" stroke="#18181b" stroke-width="6" stroke-linecap="round" />
        <path d="M 70 65 Q 90 60 110 65 L 115 75 Q 90 75 70 70 Z" fill="#262626" />
        <line x1="220" y1="90" x2="210" y2="40" stroke="#18181b" stroke-width="6" stroke-linecap="round" />
        <path d="M 190 40 Q 210 30 230 40" fill="none" stroke="#a1a1aa" stroke-width="6" stroke-linecap="round" />
        <!-- Box -->
        <rect x="0" y="10" width="120" height="90" fill="#2563eb" rx="8" />
        <rect x="0" y="5" width="120" height="20" fill="#1d4ed8" rx="4" />`;

    if (inventory.length === 0) {
        html += `<text x="60" y="60" fill="white" font-size="16" font-weight="bold" text-anchor="middle" opacity="0.6">הארגז ריק</text>`;
    } else {
        inventory.forEach((item, i) => {
            const row = Math.floor(i / 5);
            const col = i % 5;
            const xPos = 10 + col * 20;
            const yPos = 55 + row * 30;
            const emoji = item === 'steak' ? '🥩' : '🍗';
            html += `<text x="${xPos}" y="${yPos}" font-size="24" class="drop-shadow-md">${emoji}</text>`;
        });
    }

    html += `</svg>`;
    return html;
}

// --- פונקציות עזר ותצוגה ---

function renderBikes() {
    document.getElementById('shop-bike-container').innerHTML = getElectricBikeHTML(false);
    document.getElementById('delivery-bike-container').innerHTML = getElectricBikeHTML(true);
}

function updateTopUI() {
    document.getElementById('ui-day').innerText = `יום ${day}`;
    document.getElementById('ui-score').innerText = `₪${score * 50}`;
    
    const invEl = document.getElementById('ui-inventory');
    invEl.innerText = `${inventory.length} / ${maxCapacity}`;
    
    if (inventory.length === maxCapacity) {
        invEl.classList.add('text-red-300');
        invEl.classList.remove('text-white');
    } else {
        invEl.classList.remove('text-red-300');
        invEl.classList.add('text-white');
    }

    // Update buttons in shop
    const isFull = inventory.length >= maxCapacity;
    const btnSteak = document.getElementById('btn-steak');
    const btnChicken = document.getElementById('btn-chicken');
    const fullOverlay = document.getElementById('shop-full-overlay');

    if (isFull) {
        btnSteak.classList.add('opacity-50', 'grayscale', 'cursor-not-allowed');
        btnSteak.classList.remove('active:scale-95');
        btnChicken.classList.add('opacity-50', 'grayscale', 'cursor-not-allowed');
        btnChicken.classList.remove('active:scale-95');
        fullOverlay.classList.remove('hidden');
    } else {
        btnSteak.classList.remove('opacity-50', 'grayscale', 'cursor-not-allowed');
        btnSteak.classList.add('active:scale-95');
        btnChicken.classList.remove('opacity-50', 'grayscale', 'cursor-not-allowed');
        btnChicken.classList.add('active:scale-95');
        fullOverlay.classList.add('hidden');
    }

    renderBikes();
}

function showMessage(text, duration = 2000) {
    const msgBox = document.getElementById('message-box');
    const msgText = document.getElementById('message-text');
    
    msgText.innerText = text;
    msgBox.classList.remove('hidden');
    
    if(messageTimeout) clearTimeout(messageTimeout);
    messageTimeout = setTimeout(() => {
        msgBox.classList.add('hidden');
    }, duration);
}

function showScreen(screenId) {
    document.getElementById('screen-start').classList.add('hidden');
    document.getElementById('screen-shop').classList.add('hidden');
    document.getElementById('screen-delivery').classList.add('hidden');
    document.getElementById('top-ui').classList.add('hidden');

    document.getElementById(screenId).classList.remove('hidden');
    if(screenId === 'screen-shop' || screenId === 'screen-delivery') {
        document.getElementById('top-ui').classList.remove('hidden');
    }
}

// --- לוגיקת משחק עיקרית ---

function init() {
    // הזרקת דמויות
    document.getElementById('start-character-container').innerHTML = getShopCharacterHTML();
    document.getElementById('shop-character-container').innerHTML = getShopCharacterHTML();
    document.getElementById('delivery-character-container').innerHTML = getRidingCharacterHTML();
    renderBikes();
}

function startGame() {
    inventory = [];
    score = 0;
    day = 1;
    updateTopUI();
    showScreen('screen-shop');
    showMessage('!בוא נעמיס את הארגז', 3000);
}

function handleCollect(type, event) {
    if (inventory.length >= maxCapacity) return;

    // אנימציית העפה
    const rect = event.currentTarget.getBoundingClientRect();
    const startX = rect.left + rect.width / 2;
    const startY = rect.top + rect.height / 2;

    const targetElement = document.getElementById('bike-box-target');
    const targetRect = targetElement.getBoundingClientRect();
    const targetX = targetRect.left + targetRect.width / 2;
    const targetY = targetRect.top + targetRect.height / 2;

    const flyingEl = document.createElement('div');
    flyingEl.className = 'absolute z-[100] text-5xl md:text-7xl pointer-events-none fly-transition';
    flyingEl.innerText = type === 'steak' ? '🥩' : '🍗';
    flyingEl.style.left = `${startX}px`;
    flyingEl.style.top = `${startY}px`;
    flyingEl.style.transform = `translate(-50%, -50%) scale(1) rotate(0deg)`;
    
    document.getElementById('flying-layer').appendChild(flyingEl);

    // התחלת תנועה אחרי פריים אחד
    requestAnimationFrame(() => {
        requestAnimationFrame(() => {
            flyingEl.style.left = `${targetX}px`;
            flyingEl.style.top = `${targetY}px`;
            flyingEl.style.transform = `translate(-50%, -50%) scale(0.3) rotate(-180deg)`;
            flyingEl.style.opacity = '0.5';
        });
    });

    // סיום אנימציה ועדכון מצב
    setTimeout(() => {
        flyingEl.remove();
        inventory.push(type);
        updateTopUI();
    }, 450);
}

function goToDelivery() {
    showScreen('screen-delivery');
    showMessage('!צא לדרך חביבי', 2000);
    startDeliveryLoop();
}

function startDeliveryLoop() {
    customers = [];
    document.getElementById('customers-layer').innerHTML = '';
    
    if(gameLoopInterval) clearInterval(gameLoopInterval);
    
    gameLoopInterval = setInterval(() => {
        // הזזת לקוחות
        customers.forEach(c => {
            c.x -= c.speed;
        });

        // הסרת לקוחות שיצאו מהמסך
        customers = customers.filter(c => c.x > -30);

        // יצירת לקוח חדש
        if (customers.length < 3 && Math.random() < 0.03) {
            const isHungryFor = Math.random() > 0.5 ? 'steak' : 'chicken';
            const avatars = ['👨🏻', '👩🏽', '👱🏼‍♂️', '👵🏼', '👴🏽', '🧔🏻‍♂️'];
            const avatar = avatars[Math.floor(Math.random() * avatars.length)];
            
            customers.push({
                id: Date.now() + Math.random(),
                x: 120, // vw
                y: 35 + Math.random() * 30, // vh
                speed: 0.3 + Math.random() * 0.3,
                wants: isHungryFor,
                avatar: avatar,
                served: false,
                holding: null
            });
        }

        renderCustomers();

        // בדיקת סיום שלב
        if (inventory.length === 0 && document.querySelectorAll('.throw-item').length === 0) {
            clearInterval(gameLoopInterval);
            setTimeout(() => {
                day++;
                showScreen('screen-shop');
                updateTopUI();
                showMessage('!הארגז ריק, חוזרים להעמיס', 3000);
            }, 1500);
        }

    }, 30);
}

function renderCustomers() {
    const layer = document.getElementById('customers-layer');
    layer.innerHTML = ''; // רענון פשוט במקום ניהול מורכב (Vanilla JS)

    customers.forEach(c => {
        const div = document.createElement('div');
        div.className = `absolute flex flex-col items-center transition-transform ${c.served ? 'scale-110 pointer-events-none' : 'active:scale-90 scale-100 pointer-events-auto cursor-pointer'}`;
        div.style.left = `${c.x}vw`;
        div.style.top = `${c.y}vh`;
        div.style.padding = '20px';
        
        // צירוף פונקציית הלחיצה רק אם לא קיבל בשר
        if (!c.served) {
            div.onclick = () => handleThrow(c.id);
        }

        let inner = '';
        if (!c.served) {
            const emoji = c.wants === 'steak' ? '🥩' : '🍗';
            inner += `<div class="bg-white rounded-full px-3 py-1 mb-1 shadow-md border-2 border-gray-200 text-2xl animate-bounce">${emoji}</div>`;
        } else {
            const emoji = c.holding === 'steak' ? '🥩' : '🍗';
            inner += `<div class="absolute -top-6 -right-2 text-4xl animate-bounce drop-shadow-md z-30">${emoji}</div>`;
        }
        
        inner += `<div class="text-6xl md:text-7xl drop-shadow-xl">${c.avatar}</div>`;
        div.innerHTML = inner;
        layer.appendChild(div);
    });
}

function handleThrow(customerId) {
    const customer = customers.find(c => c.id === customerId);
    if (!customer || customer.served || inventory.length === 0) return;

    const itemToThrow = inventory.pop();
    updateTopUI();

    // יצירת אלמנט מעופף לזריקה
    const throwEl = document.createElement('div');
    throwEl.className = 'throw-item absolute z-40 text-4xl md:text-5xl pointer-events-none fly-transition';
    throwEl.innerText = itemToThrow === 'steak' ? '🥩' : '🍗';
    throwEl.style.left = `30vw`; // מיקום משוער של האופניים
    throwEl.style.top = `70vh`;
    throwEl.style.transform = `translate(-50%, -50%) rotate(0deg)`;
    
    document.getElementById('screen-delivery').appendChild(throwEl);

    // הזזת הבשר ללקוח
    requestAnimationFrame(() => {
        requestAnimationFrame(() => {
            throwEl.style.left = `${customer.x}vw`;
            throwEl.style.top = `${customer.y}vh`;
            throwEl.style.transform = `translate(-50%, -50%) rotate(360deg)`;
        });
    });

    // פגיעה
    setTimeout(() => {
        throwEl.remove();
        score++;
        updateTopUI();
        
        customer.served = true;
        customer.avatar = '😍';
        customer.holding = itemToThrow;
        renderCustomers(); // רענון מיידי לתצוגה של החיוך
    }, 400);
}

// התנעה
window.onload = init;

</script>
</body>
</html>
